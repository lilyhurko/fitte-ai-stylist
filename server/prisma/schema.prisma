generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Analysis {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  query           String   
  
  geminiResponse  String?  
  mistralResponse String?  
  ragResponse     String?  
  
  geminiScore     Int?
  mistralScore    Int?
  ragScore        Int?
  
  contextUsed     String?  
  
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model User {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  email          String     @unique
  name           String
  gender         String?
  password       String
  styleTags      String?   
  favoriteColors String?
  clothes        Cloth[]
  analyses       Analysis[]  
  createdAt      DateTime   @default(now())
  events         Event[]
}

model Cloth {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  category  String
  color     String?   
  style     String? 
  imageUrl  String?
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String   
  date        DateTime 
  occasion    String   
  formality   String  
  
  outfitIds   String[] @db.ObjectId 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}